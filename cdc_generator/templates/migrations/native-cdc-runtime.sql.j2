CREATE OR REPLACE FUNCTION "cdc_management"."sync_native_cdc_registration_state"(
    p_source_instance_key text,
    p_logical_table_name text
)
RETURNS void
LANGUAGE plpgsql
AS $$
DECLARE
    v_registration record;
    v_policy record;
BEGIN
    SELECT
        reg."source_instance_key",
        reg."logical_table_name",
        reg."target_schema_name",
        reg."target_table_name",
        reg."enabled"
    INTO v_registration
    FROM "cdc_management"."source_table_registration" reg
    WHERE reg."source_instance_key" = p_source_instance_key
      AND reg."logical_table_name" = p_logical_table_name;

    IF NOT FOUND THEN
        RETURN;
    END IF;

    SELECT *
    INTO v_policy
    FROM "cdc_management"."resolve_native_cdc_schedule_policy"(
        v_registration."logical_table_name",
        v_registration."target_schema_name",
        v_registration."target_table_name",
        v_registration."enabled"
    );

    INSERT INTO "cdc_management"."native_cdc_schedule_policy" (
        "source_instance_key",
        "logical_table_name",
        "enabled",
        "schedule_profile",
        "base_poll_interval_seconds",
        "min_poll_interval_seconds",
        "max_poll_interval_seconds",
        "max_rows_per_pull",
        "lease_seconds",
        "poll_priority",
        "jitter_millis",
        "max_backoff_seconds",
        "business_hours_profile_key"
    )
    VALUES (
        v_registration."source_instance_key",
        v_registration."logical_table_name",
        v_policy."enabled",
        v_policy."schedule_profile",
        v_policy."base_poll_interval_seconds",
        v_policy."min_poll_interval_seconds",
        v_policy."max_poll_interval_seconds",
        v_policy."max_rows_per_pull",
        v_policy."lease_seconds",
        v_policy."poll_priority",
        v_policy."jitter_millis",
        v_policy."max_backoff_seconds",
        v_policy."business_hours_profile_key"
    )
    ON CONFLICT ("source_instance_key", "logical_table_name") DO UPDATE
    SET
        "enabled" = EXCLUDED."enabled",
        "schedule_profile" = EXCLUDED."schedule_profile",
        "base_poll_interval_seconds" = EXCLUDED."base_poll_interval_seconds",
        "min_poll_interval_seconds" = EXCLUDED."min_poll_interval_seconds",
        "max_poll_interval_seconds" = EXCLUDED."max_poll_interval_seconds",
        "max_rows_per_pull" = EXCLUDED."max_rows_per_pull",
        "lease_seconds" = EXCLUDED."lease_seconds",
        "poll_priority" = EXCLUDED."poll_priority",
        "jitter_millis" = EXCLUDED."jitter_millis",
        "max_backoff_seconds" = EXCLUDED."max_backoff_seconds",
        "business_hours_profile_key" = EXCLUDED."business_hours_profile_key",
        "config_version" = "cdc_management"."native_cdc_schedule_policy"."config_version" + 1,
        "updated_at" = NOW()
    WHERE
        "cdc_management"."native_cdc_schedule_policy"."enabled" IS DISTINCT FROM EXCLUDED."enabled"
        OR "cdc_management"."native_cdc_schedule_policy"."schedule_profile" IS DISTINCT FROM EXCLUDED."schedule_profile"
        OR "cdc_management"."native_cdc_schedule_policy"."base_poll_interval_seconds" IS DISTINCT FROM EXCLUDED."base_poll_interval_seconds"
        OR "cdc_management"."native_cdc_schedule_policy"."min_poll_interval_seconds" IS DISTINCT FROM EXCLUDED."min_poll_interval_seconds"
        OR "cdc_management"."native_cdc_schedule_policy"."max_poll_interval_seconds" IS DISTINCT FROM EXCLUDED."max_poll_interval_seconds"
        OR "cdc_management"."native_cdc_schedule_policy"."max_rows_per_pull" IS DISTINCT FROM EXCLUDED."max_rows_per_pull"
        OR "cdc_management"."native_cdc_schedule_policy"."lease_seconds" IS DISTINCT FROM EXCLUDED."lease_seconds"
        OR "cdc_management"."native_cdc_schedule_policy"."poll_priority" IS DISTINCT FROM EXCLUDED."poll_priority"
        OR "cdc_management"."native_cdc_schedule_policy"."jitter_millis" IS DISTINCT FROM EXCLUDED."jitter_millis"
        OR "cdc_management"."native_cdc_schedule_policy"."max_backoff_seconds" IS DISTINCT FROM EXCLUDED."max_backoff_seconds"
        OR "cdc_management"."native_cdc_schedule_policy"."business_hours_profile_key" IS DISTINCT FROM EXCLUDED."business_hours_profile_key";

    INSERT INTO "cdc_management"."native_cdc_runtime_state" (
        "source_instance_key",
        "logical_table_name",
        "checkpoint_table_name",
        "current_poll_interval_seconds",
        "next_pull_at"
    )
    VALUES (
        v_registration."source_instance_key",
        v_registration."logical_table_name",
        v_registration."logical_table_name",
        v_policy."base_poll_interval_seconds",
        NOW()
    )
    ON CONFLICT ("source_instance_key", "logical_table_name") DO UPDATE
    SET
        "checkpoint_table_name" = EXCLUDED."checkpoint_table_name",
        "current_poll_interval_seconds" = COALESCE(
            "cdc_management"."native_cdc_runtime_state"."current_poll_interval_seconds",
            EXCLUDED."current_poll_interval_seconds"
        ),
        "next_pull_at" = COALESCE(
            "cdc_management"."native_cdc_runtime_state"."next_pull_at",
            EXCLUDED."next_pull_at"
        ),
        "updated_at" = NOW()
    WHERE
        "cdc_management"."native_cdc_runtime_state"."checkpoint_table_name" IS DISTINCT FROM EXCLUDED."checkpoint_table_name"
        OR "cdc_management"."native_cdc_runtime_state"."current_poll_interval_seconds" IS NULL
        OR "cdc_management"."native_cdc_runtime_state"."next_pull_at" IS NULL;
END;
$$;

