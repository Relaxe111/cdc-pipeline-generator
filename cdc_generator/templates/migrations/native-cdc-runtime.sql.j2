CREATE OR REPLACE VIEW "cdc_management"."v_native_cdc_schedule" AS
SELECT
    reg."source_instance_key",
    reg."logical_table_name",
    reg."target_schema_name",
    reg."target_table_name",
    (reg."enabled" AND si."enabled" AND policy."enabled") AS "enabled",
    policy."schedule_profile",
    policy."base_poll_interval_seconds",
    runtime."current_poll_interval_seconds" AS "poll_interval_seconds",
    policy."min_poll_interval_seconds",
    policy."max_poll_interval_seconds",
    policy."max_rows_per_pull",
    policy."lease_seconds",
    policy."poll_priority",
    policy."jitter_millis",
    policy."max_backoff_seconds",
    runtime."last_pull_started_at",
    runtime."last_pull_at",
    runtime."last_success_at",
    runtime."last_nonempty_at",
    runtime."next_pull_at",
    runtime."last_batch_rows",
    runtime."last_duration_ms",
    runtime."consecutive_failures",
    runtime."last_error",
    runtime."lease_owner",
    runtime."lease_expires_at",
    runtime."empty_pull_streak",
    policy."config_version",
    si."source_database",
    si."fdw_schema_name",
    cr."customer_id"
FROM "cdc_management"."source_table_registration" reg
JOIN "cdc_management"."native_cdc_schedule_policy" policy
    ON policy."source_instance_key" = reg."source_instance_key"
   AND policy."logical_table_name" = reg."logical_table_name"
JOIN "cdc_management"."native_cdc_runtime_state" runtime
    ON runtime."source_instance_key" = reg."source_instance_key"
   AND runtime."logical_table_name" = reg."logical_table_name"
JOIN "cdc_management"."source_instance" si
    ON si."source_instance_key" = reg."source_instance_key"
JOIN "cdc_management"."customer_registry" cr
    ON cr."customer_key" = si."customer_key";

CREATE OR REPLACE VIEW "cdc_management"."v_native_cdc_health" AS
SELECT
    reg."source_instance_key",
    reg."logical_table_name",
    reg."target_schema_name",
    reg."target_table_name",
    reg."enabled" AS "registration_enabled",
    si."enabled" AS "source_instance_enabled",
    policy."enabled" AS "policy_enabled",
    policy."schedule_profile",
    policy."base_poll_interval_seconds",
    policy."min_poll_interval_seconds",
    policy."max_poll_interval_seconds",
    runtime."current_poll_interval_seconds",
    policy."max_rows_per_pull",
    policy."lease_seconds",
    policy."poll_priority",
    policy."jitter_millis",
    policy."max_backoff_seconds",
    policy."business_hours_profile_key",
    policy."config_version",
    runtime."checkpoint_table_name",
    runtime."empty_pull_streak",
    runtime."next_pull_at",
    GREATEST(
        0::double precision,
        EXTRACT(EPOCH FROM (NOW() - runtime."next_pull_at"))
    )::bigint AS "overdue_seconds",
    runtime."lease_owner",
    runtime."lease_expires_at",
    runtime."last_pull_started_at",
    runtime."last_pull_at",
    runtime."last_success_at",
    runtime."last_nonempty_at",
    runtime."last_batch_rows",
    runtime."last_duration_ms",
    runtime."consecutive_failures",
    runtime."last_error",
    checkpoint."last_start_lsn",
    checkpoint."last_seqval",
    checkpoint."updated_at" AS "checkpoint_updated_at",
    si."source_database",
    si."fdw_schema_name",
    cr."customer_id"
FROM "cdc_management"."source_table_registration" reg
JOIN "cdc_management"."native_cdc_schedule_policy" policy
    ON policy."source_instance_key" = reg."source_instance_key"
   AND policy."logical_table_name" = reg."logical_table_name"
JOIN "cdc_management"."native_cdc_runtime_state" runtime
    ON runtime."source_instance_key" = reg."source_instance_key"
   AND runtime."logical_table_name" = reg."logical_table_name"
JOIN "cdc_management"."source_instance" si
    ON si."source_instance_key" = reg."source_instance_key"
JOIN "cdc_management"."customer_registry" cr
    ON cr."customer_key" = si."customer_key"
LEFT JOIN "cdc_management"."native_cdc_checkpoint" checkpoint
    ON checkpoint."customer_id" = cr."customer_id"
   AND checkpoint."table_name" = runtime."checkpoint_table_name";

CREATE OR REPLACE FUNCTION "cdc_management"."claim_due_native_cdc_work"(
    p_limit integer DEFAULT 100,
    p_lease_seconds integer DEFAULT NULL,
    p_worker text DEFAULT NULL
)
RETURNS TABLE(
    "source_instance_key" text,
    "logical_table_name" text,
    "target_schema_name" text,
    "target_table_name" text,
    "current_poll_interval_seconds" integer,
    "max_rows_per_pull" integer,
    "lease_seconds" integer,
    "poll_priority" integer
)
LANGUAGE plpgsql
AS $$
DECLARE
    v_worker text := COALESCE(NULLIF(p_worker, ''), 'external_scheduler');
BEGIN
    RETURN QUERY
    WITH due AS (
        SELECT
            runtime.ctid,
            runtime."source_instance_key",
            runtime."logical_table_name"
        FROM "cdc_management"."native_cdc_runtime_state" runtime
        JOIN "cdc_management"."native_cdc_schedule_policy" policy
            ON policy."source_instance_key" = runtime."source_instance_key"
           AND policy."logical_table_name" = runtime."logical_table_name"
        JOIN "cdc_management"."source_table_registration" reg
            ON reg."source_instance_key" = runtime."source_instance_key"
           AND reg."logical_table_name" = runtime."logical_table_name"
        JOIN "cdc_management"."source_instance" si
            ON si."source_instance_key" = runtime."source_instance_key"
        WHERE reg."enabled" = true
          AND policy."enabled" = true
          AND si."enabled" = true
          AND COALESCE(runtime."next_pull_at", NOW()) <= NOW()
          AND (
                runtime."lease_expires_at" IS NULL
                OR runtime."lease_expires_at" <= NOW()
          )
        ORDER BY
            COALESCE(policy."poll_priority", 100) ASC,
            COALESCE(runtime."next_pull_at", NOW()) ASC,
            runtime."source_instance_key" ASC,
            runtime."logical_table_name" ASC
        FOR UPDATE OF runtime SKIP LOCKED
        LIMIT p_limit
    ),
    claimed AS (
        UPDATE "cdc_management"."native_cdc_runtime_state" runtime
        SET
            "lease_owner" = v_worker,
            "lease_expires_at" = NOW() + make_interval(
                secs => COALESCE(
                    NULLIF(p_lease_seconds, 0),
                    policy."lease_seconds",
                    120
                )::double precision
            ),
            "last_pull_started_at" = NOW(),
            "updated_at" = NOW()
        FROM due
        JOIN "cdc_management"."native_cdc_schedule_policy" policy
            ON policy."source_instance_key" = due."source_instance_key"
           AND policy."logical_table_name" = due."logical_table_name"
        WHERE runtime.ctid = due.ctid
        RETURNING
            runtime."source_instance_key",
            runtime."logical_table_name"
    )
    SELECT
        claimed."source_instance_key",
        claimed."logical_table_name",
        reg."target_schema_name",
        reg."target_table_name",
        COALESCE(runtime."current_poll_interval_seconds", policy."base_poll_interval_seconds", 60) AS "current_poll_interval_seconds",
        COALESCE(policy."max_rows_per_pull", 1000) AS "max_rows_per_pull",
        COALESCE(NULLIF(p_lease_seconds, 0), policy."lease_seconds", 120) AS "lease_seconds",
        COALESCE(policy."poll_priority", 100) AS "poll_priority"
    FROM claimed
    JOIN "cdc_management"."source_table_registration" reg
        ON reg."source_instance_key" = claimed."source_instance_key"
       AND reg."logical_table_name" = claimed."logical_table_name"
    JOIN "cdc_management"."native_cdc_schedule_policy" policy
        ON policy."source_instance_key" = claimed."source_instance_key"
       AND policy."logical_table_name" = claimed."logical_table_name"
    JOIN "cdc_management"."native_cdc_runtime_state" runtime
        ON runtime."source_instance_key" = claimed."source_instance_key"
       AND runtime."logical_table_name" = claimed."logical_table_name"
    ORDER BY "poll_priority", claimed."source_instance_key", claimed."logical_table_name";
END;
$$;

CREATE OR REPLACE PROCEDURE "cdc_management"."renew_native_cdc_lease"(
    p_source_instance_key text,
    p_logical_table_name text,
    p_worker text DEFAULT NULL,
    p_lease_seconds integer DEFAULT NULL
)
LANGUAGE plpgsql
AS $$
DECLARE
    v_worker text := COALESCE(NULLIF(p_worker, ''), 'external_scheduler');
BEGIN
    UPDATE "cdc_management"."native_cdc_runtime_state" runtime
    SET
        "lease_expires_at" = NOW() + make_interval(
            secs => COALESCE(
                NULLIF(p_lease_seconds, 0),
                policy."lease_seconds",
                120
            )::double precision
        ),
        "updated_at" = NOW()
    FROM "cdc_management"."native_cdc_schedule_policy" policy
    WHERE runtime."source_instance_key" = p_source_instance_key
      AND runtime."logical_table_name" = p_logical_table_name
      AND policy."source_instance_key" = runtime."source_instance_key"
      AND policy."logical_table_name" = runtime."logical_table_name"
      AND runtime."lease_owner" = v_worker;
END;
$$;

CREATE OR REPLACE PROCEDURE "cdc_management"."mark_native_cdc_success"(
    p_source_instance_key text,
    p_logical_table_name text,
    p_rows bigint DEFAULT 0,
    p_duration_ms bigint DEFAULT NULL
)
LANGUAGE plpgsql
AS $$
BEGIN
    UPDATE "cdc_management"."native_cdc_runtime_state" runtime
    SET
        "last_pull_at" = NOW(),
        "last_success_at" = NOW(),
        "last_nonempty_at" = CASE
            WHEN COALESCE(p_rows, 0) > 0 THEN NOW()
            ELSE runtime."last_nonempty_at"
        END,
        "empty_pull_streak" = CASE
            WHEN COALESCE(p_rows, 0) > 0 THEN 0
            ELSE COALESCE(runtime."empty_pull_streak", 0) + 1
        END,
        "next_pull_at" = NOW()
            + make_interval(
                secs => COALESCE(
                    runtime."current_poll_interval_seconds",
                    policy."base_poll_interval_seconds",
                    60
                )::double precision
            )
            + (
                floor(random() * (GREATEST(COALESCE(policy."jitter_millis", 500), 0) + 1))::bigint
                * interval '1 millisecond'
            ),
        "last_batch_rows" = COALESCE(p_rows, 0),
        "last_duration_ms" = p_duration_ms,
        "consecutive_failures" = 0,
        "last_error" = NULL,
        "lease_owner" = NULL,
        "lease_expires_at" = NULL,
        "updated_at" = NOW()
    FROM "cdc_management"."native_cdc_schedule_policy" policy
    WHERE runtime."source_instance_key" = p_source_instance_key
      AND runtime."logical_table_name" = p_logical_table_name
      AND policy."source_instance_key" = runtime."source_instance_key"
      AND policy."logical_table_name" = runtime."logical_table_name";
END;
$$;

CREATE OR REPLACE PROCEDURE "cdc_management"."mark_native_cdc_failure"(
    p_source_instance_key text,
    p_logical_table_name text,
    p_error text,
    p_retry_seconds integer DEFAULT NULL
)
LANGUAGE plpgsql
AS $$
BEGIN
    UPDATE "cdc_management"."native_cdc_runtime_state" runtime
    SET
        "last_pull_at" = NOW(),
        "next_pull_at" = NOW()
            + make_interval(
                secs => GREATEST(
                    COALESCE(p_retry_seconds, 120),
                    COALESCE(
                        runtime."current_poll_interval_seconds",
                        policy."base_poll_interval_seconds",
                        60
                    )
                )::double precision
            )
            + (
                floor(random() * (GREATEST(COALESCE(policy."jitter_millis", 500), 0) + 1))::bigint
                * interval '1 millisecond'
            ),
        "consecutive_failures" = COALESCE(runtime."consecutive_failures", 0) + 1,
        "last_error" = p_error,
        "lease_owner" = NULL,
        "lease_expires_at" = NULL,
        "updated_at" = NOW()
    FROM "cdc_management"."native_cdc_schedule_policy" policy
    WHERE runtime."source_instance_key" = p_source_instance_key
      AND runtime."logical_table_name" = p_logical_table_name
      AND policy."source_instance_key" = runtime."source_instance_key"
      AND policy."logical_table_name" = runtime."logical_table_name";
END;
$$;

