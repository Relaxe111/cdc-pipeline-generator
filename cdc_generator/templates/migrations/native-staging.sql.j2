    INTO v_min_valid_lsn;

    IF v_min_valid_lsn IS NULL THEN
        RAISE EXCEPTION 'Could not read min LSN for {{ table_name }} from FDW schema %', v_fdw_schema;
    END IF;

    INSERT INTO "cdc_management"."native_cdc_checkpoint" (
        "customer_id",
        "table_name",
        "last_start_lsn",
        "last_seqval"
    )
    VALUES (
        v_customer_id,
        '{{ table_name }}',
        v_min_valid_lsn,
        NULL
    )
    ON CONFLICT ("customer_id", "table_name") DO NOTHING;

    SELECT
        c."last_start_lsn",
        c."last_seqval"
    INTO
        v_last_start_lsn,
        v_last_seqval
    FROM "cdc_management"."native_cdc_checkpoint" c
    WHERE c."customer_id" = v_customer_id
      AND c."table_name" = '{{ table_name }}';

    IF v_last_start_lsn < v_min_valid_lsn THEN
        RAISE EXCEPTION 'FATAL: LSN gap detected for {{ table_name }}. Last checkpoint is older than MSSQL retention horizon';
    END IF;

    v_sql := format(
        $fmt$
        INSERT INTO {{ target_schema }}."stg_{{ table_name }}" (
            {{ staging_insert_columns }}
        )
        SELECT
            $1::uuid,
            $2,
{{ pull_select_sql }}
        FROM %I.%I f
        WHERE f."__$operation" IN (1, 2, 4)
          AND (
                f."__$start_lsn" > $5::bytea
                OR (
                    f."__$start_lsn" = $5::bytea
                    AND (
                        $6::bytea IS NULL
                        OR f."__$seqval" > $6::bytea
                    )
                )
