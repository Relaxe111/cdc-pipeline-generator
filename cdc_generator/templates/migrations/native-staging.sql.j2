    EXECUTE v_sql USING
        v_batch_id,
        p_source_instance_key,
        v_customer_id,
        v_source_db,
        v_last_start_lsn,
        v_last_seqval,
        p_max_rows;

    RETURN QUERY
    SELECT
        v_batch_id,
