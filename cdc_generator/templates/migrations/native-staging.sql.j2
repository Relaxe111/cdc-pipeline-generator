        ORDER BY f."__$start_lsn", f."__$seqval"
        LIMIT $7
        $fmt$,
        v_fdw_schema,
        '{{ foreign_table_name }}'
    );

    EXECUTE v_sql USING
        v_batch_id,
        p_source_instance_key,
        v_customer_id,
        v_source_db,
        v_last_start_lsn,
        v_last_seqval,
        p_max_rows;

    RETURN QUERY
    SELECT
        v_batch_id,
        COUNT(*)::bigint
    FROM {{ target_schema }}."stg_{{ table_name }}"
    WHERE "batch_id" = v_batch_id;
END;
$$;

CREATE OR REPLACE PROCEDURE {{ target_schema }}."sp_merge_{{ table_name | lower }}"(
