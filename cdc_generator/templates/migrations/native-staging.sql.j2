RETURNS TABLE("batch_id" uuid, "rows_inserted" bigint)
LANGUAGE plpgsql
AS $$
DECLARE
    v_customer_id uuid;
    v_fdw_schema text;
    v_source_db text;
    v_last_start_lsn bytea;
    v_last_seqval bytea;
    v_min_valid_lsn bytea;
