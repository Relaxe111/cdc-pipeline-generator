{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Column Templates",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "templates": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "not_null": { "type": "boolean" },
          "description": { "type": "string" },
          "value": { "type": "string" },
          "value_source": {
            "type": "string",
            "enum": ["bloblang", "source_ref", "source-ref", "sql", "env"]
          },
          "default": { "type": "string" },
          "applies_to": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          },
          "unique": { "type": "boolean" }
        },
        "required": ["type", "value"]
      }
    }
  },
  "required": ["templates"]
}